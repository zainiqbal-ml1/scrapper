{
  "manifest_version": 2,
  "name": "CanLII PDF Bulk Download",
  "version": "1.6.0",
  "description": "Bulk-download CanLII PDFs in Tor Browser — resume, skip existing, per-year JSON.",
  "applications": {
    "gecko": {
      "id": "canlii-pdf@local",
      "strict_min_version": "91.0"
    }
  },
  "permissions": [
    "downloads",
    "tabs",
    "storage",
    "browsingData",
    "https://www.canlii.org/*"
  ],
  "browser_action": {
    "default_title": "CanLII PDFs",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "background": {
    "scripts": ["lib.js", "storage.js", "recovery.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.canlii.org/*"],
      "js": ["lib.js", "storage.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "page_bridge.js"
  ],
  "icons": {
    "48": "icon48.png"
  }
}
